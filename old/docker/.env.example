# ── Rig Tools · Docker Environment ──────────────────────────────────────────
# Copy this file to docker/.env and fill in the values.
# Never commit docker/.env to version control.

# Security — change this before deploying
SECRET_KEY=change-this-secret-key-in-production

# Application
DEBUG=false

# CORS — set to your domain in production, e.g. ["https://rigtools.example.com"]
CORS_ORIGINS=["*"]

# Streamlit + FastAPI share one port (8501) via asgi.py.
# Only override if you need to point at an external API.
API_BASE_URL=http://localhost:8501

# Supabase — fill in from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase CLI (local dev only — not used at runtime)
SUPABASE_DB_URL=postgresql://postgres:postgres@localhost:54322/postgres
SUPABASE_PROJECT_REF=your-project-ref
