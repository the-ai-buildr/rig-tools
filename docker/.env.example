# ── Rig Tools · Docker Environment ──────────────────────────────────────────
# Copy this file to docker/.env and fill in the values.
# Never commit docker/.env to version control.

# Security — change this before deploying
SECRET_KEY=change-this-secret-key-in-production

# API
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# CORS — set to your domain in production, e.g. ["https://rigtools.example.com"]
CORS_ORIGINS=["*"]

# Streamlit → API (internal Docker hostname)
API_BASE_URL=http://api:8000
